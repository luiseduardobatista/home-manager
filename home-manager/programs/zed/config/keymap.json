[
  {
    "context": "Editor && (vim_mode == normal || vim_mode == visual) && !menu",
    "bindings": {
      "ctrl-d": ["workspace::SendKeystrokes", "ctrl-d z z"],
      "ctrl-u": ["workspace::SendKeystrokes", "ctrl-u z z"],
      "ctrl-o": ["workspace::SendKeystrokes", "ctrl-o z z"],
      "ctrl-i": ["workspace::SendKeystrokes", "ctrl-i z z"],
      "n": ["workspace::SendKeystrokes", "n z z"],
      "shift-n": ["workspace::SendKeystrokes", "shift-n z z"],
      "g y": "editor::GoToTypeDefinition",
      "g r": "editor::FindAllReferences",
      "shift-k": "editor::Hover"
    }
  },
  {
    "context": "Editor && vim_mode == normal && !menu",
    "bindings": {
      "ctrl-h": "workspace::ActivatePaneLeft",
      "ctrl-j": "workspace::ActivatePaneDown",
      "ctrl-k": "workspace::ActivatePaneUp",
      "ctrl-l": "workspace::ActivatePaneRight",
      "ctrl-shift-h": "vim::ResizePaneLeft",
      "ctrl-shift-j": "vim::ResizePaneDown",
      "ctrl-shift-k": "vim::ResizePaneUp",
      "ctrl-shift-l": "vim::ResizePaneRight",
      "space -": "pane::SplitDown",
      "space |": "pane::SplitRight",
      "space s h": "pane::SplitDown",
      "space s v": "pane::SplitRight",
      "space w d": "pane::CloseActiveItem",
      "space b d": "pane::CloseActiveItem",
      "space b s": "workspace::NewFile",
      "space b c": ["workspace::SendKeystrokes", "g g V G y"],
      "space e d": "project_panel::ToggleFocus",
      "space e f": "pane::RevealInProjectPanel",
      "space e s": "zed::OpenSettings",
      "space e k": "zed::OpenKeymap",
      "space f f": "file_finder::Toggle",
      "space f b": "tab_switcher::Toggle",
      "space f g": "pane::DeploySearch",
      "space f shift-s": "outline::Toggle",
      "space f d": "diagnostics::Deploy",
      "space f v": "file_finder::Toggle",
      "space f p": "projects::OpenRecent",
      "space g o": "editor::ToggleSelectedDiffHunks",
      "space g g": "terminal_panel::Toggle",
      "space c a": "editor::ToggleCodeActions",
      "space c f": "editor::Format",
      "space c r": "editor::Rename",
      "space t t": "terminal_panel::Toggle"
    }
  },
  {
    "context": "Dock && !menu",
    "bindings": {
      "ctrl-h": "workspace::ActivatePaneLeft",
      "ctrl-j": "workspace::ActivatePaneDown",
      "ctrl-k": "workspace::ActivatePaneUp",
      "ctrl-l": "workspace::ActivatePaneRight",
      "ctrl-shift-h": "vim::ResizePaneLeft",
      "ctrl-shift-j": "vim::ResizePaneDown",
      "ctrl-shift-k": "vim::ResizePaneUp",
      "ctrl-shift-l": "vim::ResizePaneRight"
    }
  },
  {
    "context": "Terminal",
    "bindings": {
      "ctrl-h": "workspace::ActivatePaneLeft",
      "ctrl-j": "workspace::ActivatePaneDown",
      "ctrl-k": "workspace::ActivatePaneUp",
      "ctrl-l": "workspace::ActivatePaneRight"
    }
  },
  {
    "context": "Editor && vim_mode == insert",
    "bindings": {
      "ctrl-k": "editor::ShowSignatureHelp"
    }
  },
  {
    "context": "RightDock && !Editor && !Terminal && !Input",
    "bindings": {
      "q": "workspace::ToggleRightDock"
    }
  },
  {
    "context": "ProjectPanel",
    "bindings": {
      "q": "project_panel::Toggle",
      "escape": "project_panel::Toggle"
    }
  }
]
